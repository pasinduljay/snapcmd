{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snapcmd",
  "version": "0.1.0",
  "identifier": "com.snapcmd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Snapcmd",
        "width": 1000,
        "height": 700,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyQTA0MTEzODgyMkJCQkIKUldTN3V5S0lFMEdna2pZUUJnQm5kNXVCbWNrK2VveW82eXVZWGxkOGRLVjZFTUVhdVV4TEw5RDkK",
      "endpoints": [
        "https://github.com/pasinduljay/snapcmd/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
